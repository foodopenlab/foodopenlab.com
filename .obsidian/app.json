{
  "userIgnoreFilters": [
    "__pycache__",
    "**/*.py",
    "alembic",
    "node_modules",
    ".next",
    "out",
    ".coverage",
    ".venv",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    ".env*",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    ".DS_Store"
  ],
  "showUnsupportedFiles": true
}