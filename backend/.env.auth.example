# .env.auth — auth 컨테이너 전용 (auth_main.py). 이 파일을 복사해 .env.auth 로 채운다.
#   cp .env.auth.example .env.auth
# 실제 .env.auth 는 커밋 금지(.gitignore: .env.*).
#
# 키 생성:  bash scripts/generate_jwt_keys.sh
#   → 출력된 JWT_PRIVATE_KEY_B64 / JWT_PUBLIC_KEY_B64 를 아래에 붙여넣기.
#
# ⚠️ JWT_PRIVATE_KEY_B64 는 auth 컨테이너에만 둔다. 비즈니스 backend(.env)에는 절대 넣지 말 것.

# 발급 개인키 (RS256, base64 인코딩된 PEM) — 이 컨테이너 전용
JWT_PRIVATE_KEY_B64=

# 검증 공개키 (base64 PEM) — auth의 JWKS 노출·자체 검증용
JWT_PUBLIC_KEY_B64=

# 토큰 헤더 kid (JWKS의 kid와 일치해야 함)
JWT_KID=auth-key-1

# 토큰 대상(aud) — 검증 측 SERVICE_AUD와 일치해야 함
SERVICE_AUD=foodopenlab-api

# access token 수명(분) / refresh 수명(초, 기본 14일)
AUTH_ACCESS_TTL_MIN=10
AUTH_REFRESH_TTL_SEC=1209600

# cross-origin 쿠키를 받을 프론트 오리진(콤마 구분, 기본값 외 추가 시)
AUTH_CORS_ORIGINS=

# ───────────────────────────────────────────────────────────────────
# 비즈니스 backend( ./backend/.env )에는 아래 한 줄만 추가하면 된다(검증 전용):
#   JWT_PUBLIC_KEY_B64=<위와 동일한 공개키>
#   SERVICE_AUD=foodopenlab-api
# 개인키는 넣지 않는다.
